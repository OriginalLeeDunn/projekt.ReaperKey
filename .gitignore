# ── Secrets ──────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
config.toml
!config.toml.example

# ── Rust ─────────────────────────────────────────────────────────────────────
/target/
**/*.rs.bk

# ── Node / TypeScript SDK + Example ─────────────────────────────────────────
sdk/node_modules/
sdk/dist/
sdk/.turbo/
sdk/coverage/
example/node_modules/
example/dist/
