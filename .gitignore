# ── SQLite databases ─────────────────────────────────────────────────────────
# db/ directory is tracked via db/.gitkeep; ignore the actual database files inside it
db/*.db
db/*.db-shm
db/*.db-wal
*.sqlite
*.sqlite3
# Catch stray root-level db files from older versions
/*.db
/*.db-shm
/*.db-wal

# ── Coverage / test artifacts ─────────────────────────────────────────────────
tarpaulin-report.html
lcov.info
coverage/

