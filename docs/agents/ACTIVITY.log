{"ts": "2026-03-28T10:56:56.890499+00:00", "event_type": "claude", "agent": "Claude", "action": "Bash", "detail": "python3 -c \"\nimport json\nagents = {}\ntypes = {}\nwith open('/mnt/data4tb/Warehouse/web3-sdk/docs/agents/ACTIVITY.log') as f:\n    for line in f:\n        line=line.strip()\n        if not line: continue\n        try:\n            e = json.loads(line)\n            a = e.get('agent','?')\n            t = e.get('event_type','?')\n            agents[a] = agents.get(a,0)+1\n            types[t] = types.get(t,0)+1\n        except: pass\nprint('=== By event_type ===')\nfor k,v in sorted(types.items()): print(f'  {k:12} {v}')\nprint()\nprint('=== By agent (non-Claude) ===')\nfor k,v in sorted(agents.items()):\n    if k != 'Claude': print(f'  {k:25} {v}')\n\"", "status": "ok"}
