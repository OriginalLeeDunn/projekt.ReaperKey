{"ts": "2026-03-28T10:54:45.272216+00:00", "event_type": "claude", "agent": "Claude", "action": "Bash", "detail": "python3 -c \"\nimport json\nlines = open('/mnt/data4tb/Warehouse/web3-sdk/docs/agents/ACTIVITY.log').readlines()\nclean = []\nfor line in lines:\n    line = line.strip()\n    if not line: continue\n    try:\n        e = json.loads(line)\n        # Remove test entries and the wrong 'api' type entry\n        if e.get('action') == 'channel_test': continue\n        if e.get('event_type') == 'api': continue\n        if e.get('event_type') is None and e.get('agent') == 'Claude' and e.get('action') == 'test': continue\n        clean.append(line)\n    except:\n        clean.append(line)\nopen('/mnt/data4tb/Warehouse/web3-sdk/docs/agents/ACTIVITY.log','w').write('\\n'.join(clean)+'\\n')\nprint(f'Cleaned: {len(lines)} \u2192 {len(clean)} lines')\n\"", "status": "ok"}
